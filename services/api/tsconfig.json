{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "aws-lambda"],
    "outDir": ".build"
  },
  "include": ["src/**/*.ts", "serverless.ts"],
  "exclude": ["node_modules", ".serverless", ".build"]
}
